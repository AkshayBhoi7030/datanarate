# =============================================
# DataNarrate Production Environment Variables
# =============================================

# ---------------------------------------------
# Database Configuration
# ---------------------------------------------
# Connection URL for Neon PostgreSQL
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# ---------------------------------------------
# Cache Configuration
# ---------------------------------------------
# Connection URL for Redis Cloud
REDIS_URL=

# ---------------------------------------------
# Security Configuration
# ---------------------------------------------
# Secret key for JWT token generation
# Generate a secure random string (e.g., using `openssl rand -hex 32`)
SECRET_KEY=

# Application environment (production, staging, development)
ENVIRONMENT=production

# ---------------------------------------------
# AI/LLM Configuration
# ---------------------------------------------
# URL for Ollama service
# For production, consider using a hosted LLM service like OpenAI or Anthropic
OLLAMA_URL=http://localhost:11434

# ---------------------------------------------
# Logging Configuration
# ---------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ---------------------------------------------
# CORS Configuration
# ---------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-datanarrate-app.vercel.app,http://localhost:3000

# ---------------------------------------------
# PostgreSQL (for docker-compose.prod.yml only)
# ---------------------------------------------
POSTGRES_USER=datanarrate
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=datanarrate
